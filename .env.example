# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth2
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Yahoo OAuth2
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=

# OAuth2 Redirect URI
OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
OAUTH_CALLBACK_PORT=3000

# Config file path (optional, defaults to OS-specific path)
MCP_EMAIL_CONFIG=

# Log level: debug | info | warn | error
LOG_LEVEL=info
