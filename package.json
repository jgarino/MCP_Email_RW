{
  "name": "mcp-email-rw",
  "version": "0.1.0",
  "description": "MCP server for complete email management — read, write, search, delete via IMAP/POP3/SMTP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-email-rw": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgarino/MCP_Email_RW.git"
  },
  "keywords": [
    "mcp",
    "email",
    "imap",
    "smtp",
    "pop3"
  ],
  "author": "",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/jgarino/MCP_Email_RW/issues"
  },
  "homepage": "https://github.com/jgarino/MCP_Email_RW#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.18.0",
    "imapflow": "^1.2.11",
    "mailparser": "^3.9.3",
    "nodemailer": "^8.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/nodemailer": "^7.0.11",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
